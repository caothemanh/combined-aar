name: Build AAR

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    env:
      GOTOOLCHAIN: local

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Go
        uses: actions/setup-go@v5
        with:
          go-version: 1.23.7

      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Setup Android SDK
        uses: android-actions/setup-android@v3

      - name: Clone x/mobile
        run: |
          cd /tmp

          git clone https://github.com/golang/mobile.git

          cd mobile

          git checkout 76ac6878050a

          go build -o ~/go/bin/gobind ./cmd/gobind
          go build -o ~/go/bin/gomobile ./cmd/gomobile

      - name: Prepare modules
        run: |
          echo 'replace golang.org/x/mobile => /tmp/mobile' >> go.mod

          go mod tidy

      - name: Build AAR
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin

          gomobile bind \
            -target=android \
            -androidapi 21 \
            -o combined.aar \
            ./lib

      - name: Upload AAR
        uses: actions/upload-artifact@v4
        with:
          name: combined-aar
          path: combined.aar